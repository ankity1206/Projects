#!/bin/sh
# packaging/linux/appimage/AppRun
#
# This is the entry point of the AppImage squashfs.
# It runs with APPDIR set to the mount point of the squashfs.
# We set up library paths and exec the launcher.
#
# AppImage spec: https://docs.appimage.org/packaging-guide/

set -e

# APPDIR is set by the AppImage runtime to the squashfs mount point.
# Fallback for testing outside AppImage:
if [ -z "$APPDIR" ]; then
    APPDIR="$(cd "$(dirname "$0")" && pwd)"
fi

# ── Bundled library paths ────────────────────────────────────────────
APPLIB="$APPDIR/usr/lib"

# Prepend our bundled libs — system libs take precedence via RUNPATH
# in the binary, but our bundled ones fill in anything missing.
if [ -n "$LD_LIBRARY_PATH" ]; then
    export LD_LIBRARY_PATH="$APPLIB:$APPLIB/x86_64-linux-gnu:$LD_LIBRARY_PATH"
else
    export LD_LIBRARY_PATH="$APPLIB:$APPLIB/x86_64-linux-gnu"
fi

# ── XDG data dirs ─────────────────────────────────────────────────────
if [ -n "$XDG_DATA_DIRS" ]; then
    export XDG_DATA_DIRS="$APPDIR/usr/share:$XDG_DATA_DIRS"
else
    export XDG_DATA_DIRS="$APPDIR/usr/share:/usr/local/share:/usr/share"
fi

# ── Qt plugin path (if Qt UI is bundled) ─────────────────────────────
export QT_PLUGIN_PATH="$APPDIR/usr/lib/qt6/plugins:${QT_PLUGIN_PATH:-}"
export QT_QPA_PLATFORM_PLUGIN_PATH="$APPDIR/usr/lib/qt6/plugins/platforms"

# ── Wayland / X11 ────────────────────────────────────────────────────
# Prefer Wayland if available, fallback to xcb
if [ -z "$QT_QPA_PLATFORM" ]; then
    if [ -n "$WAYLAND_DISPLAY" ]; then
        export QT_QPA_PLATFORM="wayland;xcb"
    else
        export QT_QPA_PLATFORM="xcb"
    fi
fi

# ── High DPI ─────────────────────────────────────────────────────────
export QT_AUTO_SCREEN_SCALE_FACTOR=1
export QT_ENABLE_HIGHDPI_SCALING=1

# ── Exec the launcher ────────────────────────────────────────────────
# The launcher is a tiny Go binary (no cgo, no PDF engine).
# It handles first-run setup and then exec()s the main pdfmaster binary.
LAUNCHER="$APPDIR/usr/bin/pdfmaster-launcher"

if [ ! -x "$LAUNCHER" ]; then
    # Fallback: exec main binary directly if launcher not present
    LAUNCHER="$APPDIR/usr/bin/pdfmaster"
fi

exec "$LAUNCHER" "$@"
